generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ============ 認証 ============
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(MEMBER)
  isActive      Boolean   @default(true)
  locale        String    @default("ja")
  accounts      Account[]
  sessions      Session[]
  clinics       ClinicUser[]
  auditLogs     AuditLog[]
  notifications Notification[]
  dashboardLayouts DashboardLayout[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

// ============ 組織・医院 ============
model Organization {
  id        String   @id @default(cuid())
  name      String
  clinics   Clinic[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Clinic {
  id              String         @id @default(cuid())
  organizationId  String?
  organization    Organization?  @relation(fields: [organizationId], references: [id])
  clinicName      String
  corporateName   String?
  prefecture      String?
  city            String?
  address         String?
  openingYear     Int?
  corporateType   CorporateType  @default(INDIVIDUAL)
  clinicType      String         @default("[]")
  isHomeVisit     Boolean        @default(false)
  isSetupComplete Boolean        @default(false)

  users                   ClinicUser[]
  profiles                ClinicProfile[]
  monthlyRevenue          MonthlyRevenue[]
  monthlyPatients         MonthlyPatients[]
  monthlyAppointments     MonthlyAppointments[]
  monthlyCosts            MonthlyCosts[]
  monthlyKpis             MonthlyKpis[]
  uploadFiles             UploadFile[]
  importJobs              ImportJob[]
  importMappings          ImportMapping[]
  allocationRules         AllocationRule[]
  allocationDriverValues  AllocationDriverValue[]
  allocationResults       AllocationResult[]
  departmentProfitability DepartmentProfitability[]
  aiInsights              AiInsight[]
  actionPlans             ActionPlan[]
  targets                 ClinicTarget[]
  invitations             Invitation[]
  customCostItems         CustomCostItem[]
  customDrivers           CustomDriver[]
  customBenchmarks        CustomBenchmark[]
  kpiDisplaySettings      KpiDisplaySetting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClinicUser {
  id       String   @id @default(cuid())
  userId   String
  clinicId String
  role     UserRole @default(MEMBER)
  user     User     @relation(fields: [userId], references: [id])
  clinic   Clinic   @relation(fields: [clinicId], references: [id])
  @@unique([userId, clinicId])
}

enum CorporateType {
  INDIVIDUAL
  CORPORATION
}

// ============ 医院プロファイル ============
model ClinicProfile {
  id                     String   @id @default(cuid())
  clinicId               String
  clinic                 Clinic   @relation(fields: [clinicId], references: [id])
  targetYearMonth        String?
  // 規模・設備
  unitCount              Int      @default(0)
  activeUnitCount        Int      @default(0)
  hasCt                  Boolean  @default(false)
  hasMicroscope          Boolean  @default(false)
  hasCadcam              Boolean  @default(false)
  hasOperationRoom       Boolean  @default(false)
  // 人員構成
  fulltimeDentistCount   Int      @default(0)
  parttimeDentistCount   Int      @default(0)
  fulltimeHygienistCount Int      @default(0)
  parttimeHygienistCount Int      @default(0)
  fulltimeAssistantCount Int      @default(0)
  parttimeAssistantCount Int      @default(0)
  fulltimeReceptionCount Int      @default(0)
  parttimeReceptionCount Int      @default(0)
  fulltimeTechnicianCount Int     @default(0)
  parttimeTechnicianCount Int     @default(0)
  hasOfficeManager       Boolean  @default(false)
  // 稼働条件
  clinicDaysPerMonth     Int      @default(22)
  avgHoursPerDay         Float    @default(8)
  avgOvertimeHours       Float    @default(0)
  workHours              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([clinicId, targetYearMonth])
}

// ============ 目標値 ============
model ClinicTarget {
  id                        String   @id @default(cuid())
  clinicId                  String
  clinic                    Clinic   @relation(fields: [clinicId], references: [id])
  yearMonth                 String?
  monthlyRevenue            Float?
  selfPayRatio              Float?
  newPatients               Int?
  returnRate                Float?
  cancelRate                Float?
  laborCostRatio            Float?
  materialCostRatio         Float?
  maintenanceTransitionRate Float?
  grossProfitRate           Float?
  operatingProfitRate       Float?
  revenuePerUnit            Float?
  revenuePerActiveUnit      Float?
  revenuePerDentist         Float?
  revenuePerHygienist       Float?
  discontinuedRate          Float?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([clinicId, yearMonth])
}

// ============ データ取込 ============
model UploadFile {
  id         String       @id @default(cuid())
  clinicId   String
  clinic     Clinic       @relation(fields: [clinicId], references: [id])
  fileName   String
  fileType   FileType
  fileSize   Int
  filePath   String?
  status     ImportStatus @default(PENDING)
  errorLog   String?
  importJobs ImportJob[]
  createdAt  DateTime     @default(now())
}

model ImportJob {
  id             String       @id @default(cuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id])
  uploadFileId   String?
  uploadFile     UploadFile?  @relation(fields: [uploadFileId], references: [id])
  sourceType     SourceType   @default(CSV)
  status         ImportStatus @default(PENDING)
  totalRows      Int          @default(0)
  importedRows   Int          @default(0)
  errorRows      Int          @default(0)
  errorLog       String?
  mappingJson    String?
  yearMonth      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ImportMapping {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  name        String
  mappingJson String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum FileType {
  CSV
  PDF
}

enum SourceType {
  CSV
  PDF
  MANUAL
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
}

// ============ 月次売上 ============
model MonthlyRevenue {
  id                 String         @id @default(cuid())
  clinicId           String
  clinic             Clinic         @relation(fields: [clinicId], references: [id])
  yearMonth          String
  departmentType     DepartmentType
  revenueType        RevenueType    @default(TREATMENT)
  insuranceOrPrivate InsuranceType  @default(INSURANCE)
  amount             Float          @default(0)
  points             Int            @default(0)
  patientCount       Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([clinicId, yearMonth, departmentType, revenueType, insuranceOrPrivate])
}

enum DepartmentType {
  INSURANCE
  SELF_PAY
  MAINTENANCE
  HOME_VISIT
  RETAIL
  OTHER
  TOTAL
}

enum RevenueType {
  TREATMENT
  PREVENTION
  PROSTHETIC
  IMPLANT
  ORTHODONTIC
  OTHER
}

enum InsuranceType {
  INSURANCE
  PRIVATE
  MIXED
}

// ============ 月次患者数 ============
model MonthlyPatients {
  id                         String         @id @default(cuid())
  clinicId                   String
  clinic                     Clinic         @relation(fields: [clinicId], references: [id])
  yearMonth                  String
  departmentType             DepartmentType @default(TOTAL)
  totalPatientCount          Int            @default(0)
  uniquePatientCount         Int            @default(0)
  newPatientCount            Int            @default(0)
  returnPatientCount         Int            @default(0)
  dropoutCount               Int            @default(0)
  maintenanceTransitionCount Int            @default(0)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  @@unique([clinicId, yearMonth, departmentType])
}

// ============ 月次予約 ============
model MonthlyAppointments {
  id               String         @id @default(cuid())
  clinicId         String
  clinic           Clinic         @relation(fields: [clinicId], references: [id])
  yearMonth        String
  departmentType   DepartmentType @default(TOTAL)
  appointmentCount Int            @default(0)
  cancelCount      Int            @default(0)
  noShowCount      Int            @default(0)
  completedCount   Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([clinicId, yearMonth, departmentType])
}

// ============ 月次コスト ============
model MonthlyCosts {
  id               String         @id @default(cuid())
  clinicId         String
  clinic           Clinic         @relation(fields: [clinicId], references: [id])
  yearMonth        String
  costItemCode     String
  departmentType   DepartmentType @default(TOTAL)
  costLayer        CostLayer      @default(INDIRECT)
  amount           Float          @default(0)
  memo             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // isDirectCost/isDirectAssigned を CostLayer enum に統合
  @@unique([clinicId, yearMonth, costItemCode, departmentType])
}

enum CostLayer {
  DIRECT
  DIRECT_ASSIGNED
  INDIRECT
}

// ============ 月次KPI ============
model MonthlyKpis {
  id                  String   @id @default(cuid())
  clinicId            String
  clinic              Clinic   @relation(fields: [clinicId], references: [id])
  yearMonth           String
  kpiCode             String
  kpiValue            Float    @default(0)
  comparisonPrevMonth Float?
  comparisonPrevYear  Float?
  targetValue         Float?
  achievementRate     Float?
  benchmarkValue      Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([clinicId, yearMonth, kpiCode])
}

// ============ 配賦ルール ============
model AllocationRule {
  id                   String         @id @default(cuid())
  clinicId             String
  clinic               Clinic         @relation(fields: [clinicId], references: [id])
  costItemCode         String
  allocationTargetType DepartmentType
  driverType           String
  driverRatio          Float          @default(0)
  manualOverride       Boolean        @default(false)
  effectiveFrom        String?
  effectiveTo          String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([clinicId, costItemCode, allocationTargetType])
}

// ============ ドライバー量 ============
model AllocationDriverValue {
  id             String         @id @default(cuid())
  clinicId       String
  clinic         Clinic         @relation(fields: [clinicId], references: [id])
  yearMonth      String
  driverType     String
  departmentType DepartmentType
  driverValue    Float          @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([clinicId, yearMonth, driverType, departmentType])
}

// ============ 配賦結果 ============
model AllocationResult {
  id                     String         @id @default(cuid())
  clinicId               String
  clinic                 Clinic         @relation(fields: [clinicId], references: [id])
  yearMonth              String
  costItemCode           String
  departmentType         DepartmentType
  driverType             String
  driverRate             Float          @default(0)
  allocatedAmount        Float          @default(0)
  manualAdjustmentAmount Float          @default(0)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([clinicId, yearMonth, costItemCode, departmentType])
}

// ============ 部門別採算 ============
model DepartmentProfitability {
  id                            String         @id @default(cuid())
  clinicId                      String
  clinic                        Clinic         @relation(fields: [clinicId], references: [id])
  yearMonth                     String
  departmentType                DepartmentType
  revenue                       Float          @default(0)
  directCost                    Float          @default(0)
  grossProfit                   Float          @default(0)
  grossMargin                   Float          @default(0)
  directAssignedCost            Float          @default(0)
  preAllocationProfit           Float          @default(0)
  preAllocationMargin           Float          @default(0)
  allocatedIndirectCost         Float          @default(0)
  postAllocationOperatingProfit Float          @default(0)
  operatingMargin               Float          @default(0)
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt

  @@unique([clinicId, yearMonth, departmentType])
}

// ============ AI分析 ============
model AiInsight {
  id             String   @id @default(cuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  yearMonth      String
  category       String
  area           String
  title          String
  description    String
  cause          String?
  suggestion     String
  expectedImpact String?
  impact         String
  difficulty     String
  priority       Int      @default(0)
  createdAt      DateTime @default(now())
}

model ActionPlan {
  id          String       @id @default(cuid())
  clinicId    String
  clinic      Clinic       @relation(fields: [clinicId], references: [id])
  insightId   String?
  title       String
  description String
  status      ActionStatus @default(TODO)
  dueDate     DateTime?
  assignee    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ActionStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

// ============ 招待 ============
model Invitation {
  id        String       @id @default(cuid())
  clinicId  String
  clinic    Clinic       @relation(fields: [clinicId], references: [id])
  email     String
  role      UserRole     @default(MEMBER)
  token     String       @unique
  expiresAt DateTime
  accepted  Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@unique([clinicId, email])
}

// ============ 監査ログ ============
model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  clinicId   String?
  action     String
  entity     String
  entityId   String?
  detail     String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

// ============ 通知 ============
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clinicId  String?
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// ============ ダッシュボードレイアウト ============
model DashboardLayout {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clinicId  String?
  layoutJson String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clinicId])
}

// ============ カスタムマスタ ============
model CustomCostItem {
  id       String  @id @default(cuid())
  clinicId String
  clinic   Clinic  @relation(fields: [clinicId], references: [id])
  code     String
  name     String
  isIndirect Boolean @default(true)
  isActive Boolean @default(true)
  sortOrder Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, code])
}

model CustomDriver {
  id       String  @id @default(cuid())
  clinicId String
  clinic   Clinic  @relation(fields: [clinicId], references: [id])
  code     String
  name     String
  isActive Boolean @default(true)
  sortOrder Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, code])
}

model CustomBenchmark {
  id        String  @id @default(cuid())
  clinicId  String
  clinic    Clinic  @relation(fields: [clinicId], references: [id])
  kpiCode   String
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, kpiCode])
}

// ============ KPI表示設定 ============
model KpiDisplaySetting {
  id        String  @id @default(cuid())
  clinicId  String
  clinic    Clinic  @relation(fields: [clinicId], references: [id])
  kpiCode   String
  isVisible Boolean @default(true)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, kpiCode])
}
